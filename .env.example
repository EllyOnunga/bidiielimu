# ─────────────────────────────────────────────
# Scholara Platform — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Django
DEBUG=False
SECRET_KEY=change-me-to-a-secure-random-secret-key-at-least-50-chars
ALLOWED_HOSTS=localhost,127.0.0.1,.scholara.app
CORS_ALLOWED_ORIGINS=http://localhost,https://*.scholara.app

# Database
POSTGRES_DB=scholara
POSTGRES_USER=scholara_user
POSTGRES_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=Scholara <noreply@scholara.app>

# Africa's Talking (SMS)
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key

# AWS S3 / Cloudflare R2 (Media Storage)
USE_S3=False
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=scholara-media
AWS_S3_REGION_NAME=af-south-1

# Sentry (Error Tracking)
SENTRY_DSN=

# M-Pesa Daraja API
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://api.scholara.app/api/v1/fees/mpesa-callback/
